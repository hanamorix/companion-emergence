{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Companion Emergence",
  "version": "0.0.11",
  "identifier": "com.companion-emergence.app",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build && bash build_python_runtime.sh",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Companion Emergence",
        "width": 900,
        "height": 560,
        "minWidth": 720,
        "minHeight": 460,
        "decorations": true,
        "alwaysOnTop": false,
        "useHttpsScheme": false
      }
    ],
    "macOSPrivateApi": true,
    "security": {
      "csp": "default-src 'self'; script-src 'self'; img-src 'self' data: blob:; font-src 'self'; style-src 'self' 'unsafe-inline'; connect-src 'self' http://127.0.0.1:* http://localhost:* http://tauri.localhost:* ws://127.0.0.1:* ws://localhost:* ws://tauri.localhost:*"
    }
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://raw.githubusercontent.com/hanamorix/companion-emergence/latest-release/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDk2QUEyMjMzMEY3MTRENDkKUldSSlRYRVBNeUtxbHZBaGpZRHd5WW9KOUtzM3N5Y2xiRFRKTzRtRWt4SW5RU1BIQnVYd2srVm4K",
      "windows": {
        "installMode": "passive"
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": ["python-runtime/**/*"],
    "macOS": {
      "signingIdentity": "-"
    }
  }
}
